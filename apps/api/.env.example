# =============================
# PHONBOT API — Umgebungsvariablen
# =============================

# === Datenbank (Supabase PostgreSQL) ===
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:6543/postgres?sslmode=require
# Direct/session-capable URL for schema migrations. Do not use transaction-pooler URLs here.
MIGRATION_DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres?sslmode=require
# Local/self-hosted only. Production should verify TLS certificates.
DB_REJECT_UNAUTHORIZED=true

# === Redis (optional, fällt auf In-Memory zurück) ===
REDIS_URL=redis://localhost:6379

# === Auth ===
JWT_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel
# Audit-Round-13: Pflicht in prod (env.ts wirft beim Boot wenn fehlt).
# Fuer Migrations einfach den gleichen Wert wie JWT_SECRET nehmen — keine
# Customer-Webhook-Signaturen brechen, weil die HMAC-Ableitung deterministisch
# am Key haengt. Sobald gesetzt kann JWT_SECRET unabhaengig rotiert werden
# ohne Customer-Webhook-Validators zu killen.
WEBHOOK_SIGNING_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel

# === Retell AI (Pflicht) ===
RETELL_API_KEY=key_...
# Voice-default: Premium-Qualitaet fuer Phonbot-Demos und produktive Agenten.
# RETELL_LLM_FAST_TIER=true setzt Retell model_high_priority=true (Fast Tier, hoehere Kosten).
RETELL_LLM_MODEL=gpt-5.4-mini
RETELL_LLM_FAST_TIER=true
# Knowledge Base readiness polling during deploy. If indexing does not finish,
# deploy fails instead of attaching an incomplete KB to the live agent.
RETELL_KB_READY_TIMEOUT_MS=45000
RETELL_KB_READY_INTERVAL_MS=2000
# Retell KB orphan sweep modes: off | dry_run | delete.
# true/yes are treated as dry_run for safety. Use delete only with a runbook.
RETELL_KB_ORPHAN_CLEANUP=dry_run
RETELL_KB_ORPHAN_MIN_AGE_MS=3600000
RETELL_KB_ORPHAN_MAX_DELETES_PER_RUN=5
RETELL_PENDING_KB_PROTECTION_DAYS=3
RETELL_REPLACED_KB_STANDBY_DAYS=14
RETELL_DELETE_REPLACED_KB_IMMEDIATELY=false
# Enables provider-neutral own KB search tool for Retell/OpenAI-Web.
# Keep false until ingestion + shadow eval gates pass.
OWN_KB_SEARCH_ENABLED=false
OWN_KB_ROLLOUT_ALLOW_ALL=false
OWN_KB_ROLLOUT_ALLOWED_ORG_IDS=
OWN_KB_ROLLOUT_ALLOWED_TENANT_IDS=
OWN_KB_ROLLOUT_ALLOWED_AGENT_IDS=
OWN_KB_CANARY_DEPLOY_UNLOCKED=false
OWN_KB_CANARY_APPROVED_0_5B_ARTIFACT_ID=
OWN_KB_CANARY_APPROVED_0_5B_ARTIFACT_SHA256=
OWN_KB_CANARY_APPROVED_0_5B_DECISION=
OWN_KB_CANARY_APPROVED_0_5B_ATTESTATION_PATH=
OWN_KB_PRIMARY_DEPLOY_UNLOCKED=false
OWN_KB_PRIMARY_APPROVED_0_5B_ARTIFACT_ID=
OWN_KB_PRIMARY_APPROVED_0_5B_ARTIFACT_SHA256=
OWN_KB_PRIMARY_APPROVED_0_5B_DECISION=
OWN_KB_PRIMARY_APPROVED_0_5B_ATTESTATION_PATH=
OWN_KB_PRIMARY_CANARY_WITHOUT_P0_DAYS=0
OWN_KB_PRIMARY_RETELL_STANDBY_DAYS=0
OWN_KB_PRIMARY_NO_UNRESOLVED_P1=false
OWN_KB_PRIMARY_LATENCY_GATES_PASSED=false
OWN_KB_PRIMARY_QUALITY_GATES_PASSED=false
OWN_KB_PRIMARY_SAFETY_GATES_PASSED=false
OWN_KB_PRIMARY_RETELL_STANDBY_READY=false
OWN_KB_PRIMARY_ROLLBACK_TESTED=false
OWN_KB_PRIMARY_KILL_SWITCH_TESTED=false
OWN_KB_PRIMARY_PRODUCT_KPI_GATES_PASSED=false
OWN_KB_PRIMARY_EXCEPTION_PATH_SLO_REPORTED=false
OWN_KB_MAX_VECTOR_DISTANCE=0.38
OWN_KB_QUERY_EMBED_TIMEOUT_MS=700
# Optional OCR for scanned PDFs in agent knowledge. Uses OPENAI_API_KEY and only runs
# when a PDF cannot be scanned as text locally. Keep disabled until you accept
# sending scanned PDF bytes to the external OCR model/subprocessor.
KNOWLEDGE_OCR_ALLOW_EXTERNAL_PROCESSOR=false
KNOWLEDGE_OCR_MODEL=gpt-4o-mini
KNOWLEDGE_OCR_TIMEOUT_MS=45000
KNOWLEDGE_OCR_MAX_PDF_BYTES=15728640
# Für automatische Rückrufe: provisionierte Retell-Nummer (Format: +49...)
RETELL_OUTBOUND_NUMBER=

# === Stripe Billing (Pflicht für Paid Plans) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monatliche Preise
STRIPE_PRICE_NUMMER=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
# Jährliche Preise (optional, aktiviert Jahres-Toggle im Dashboard)
STRIPE_PRICE_NUMMER_YEARLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_AGENCY_YEARLY=price_...

# === E-Mail (Resend) ===
RESEND_API_KEY=re_...
EMAIL_FROM=Phonbot <noreply@phonbot.de>

# === App URL (Production) ===
APP_URL=https://phonbot.de

# === Webhook URLs ===
WEBHOOK_BASE_URL=https://phonbot.de

# === Twilio (optionale Telefonnummer) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional fuer SMS. Wenn leer, nutzt SMS TWILIO_FROM_NUMBER. Alternativ Messaging Service nutzen.
TWILIO_SMS_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_BASE_URL=https://phonbot.de
# Verifier-Trunk fuer den /phone/verify-forwarding Loop-Test.
# MUSS eine Twilio-Nummer sein, die NICHT in Retell importiert wurde — sonst
# faengt Retell den Verifier-Outbound ab und der Loop schliesst nicht.
# Wenn leer, gibt /phone/verify-forwarding 503 zurueck und das UI zeigt
# manuelle Test-Anleitung statt Fake-Erfolg.
VERIFIER_TWILIO_NUMBER=

# === OpenAI (für Chat-Feature) ===
OPENAI_API_KEY=sk-...
# Hauptmodell für agent-runtime + copilot (Tool-Calling erforderlich).
# Known-good: gpt-4o, gpt-4o-mini, gpt-4.1, gpt-4.1-mini, gpt-5, gpt-5-mini, gpt-5.4, gpt-5.4-mini.
OPENAI_MODEL=gpt-4o-mini
# Embedding-Modell für Vektorsuche (insights). Default: text-embedding-3-small.
OPENAI_EMBED_MODEL=text-embedding-3-small
# Transkript-Modell für Voice-Calls (Twilio-Bridge). Default: whisper-1.
OPENAI_TRANSCRIBE_MODEL=whisper-1
# OpenAI Realtime-Modell (Twilio-Bridge). Default: gpt-4o-realtime-preview-2024-12-17.
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# === Google Calendar OAuth (optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://phonbot.de/api/calendar/google/callback

# === Microsoft Calendar OAuth (Azure App Registration) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://phonbot.de/api/calendar/microsoft/callback

# === Error Tracking (optional) ===
SENTRY_DSN=

# === Chat-Budget / Rate-Limits ===
# Max /chat-Requests pro Org pro Tag (UTC). Default 300. Einmalige
# /chat-Anfrage kann bis zu 6 OpenAI-Roundtrips (Tool-Loop) triggern.
CHAT_DAILY_BUDGET_PER_ORG=300

# === Retell-Agent-Tuning (optional, Runtime-overridable) ===
# Interruption-Sensitivity 0..1 (hoeher = aggressiver unterbrechen). Default 0.8.
RETELL_AGENT_INTERRUPTION_SENSITIVITY=0.75
# Backchannel-Noises ("mhm", "ja") aktivieren. Default false ("true" aktiviert).
RETELL_AGENT_BACKCHANNEL=false
# Reminder nach Agent-Frage bei Stille. Default 5500 ms / 1 Reminder.
RETELL_AGENT_REMINDER_TRIGGER_MS=5500
RETELL_AGENT_REMINDER_MAX_COUNT=1
# HQ-Default-Voice wenn ein Agent-Config keine explizite voice_id hat.
# Quality-first: native German ElevenLabs Ben voice, with Cartesia Sonic fallback.
RETELL_DEFAULT_VOICE_ID=custom_voice_74a89687ae8c8f1ad19e239e7c
RETELL_DEFAULT_VOICE_MODEL=eleven_multilingual_v2
RETELL_DEFAULT_VOICE_TEMPERATURE=0.55
RETELL_DEFAULT_FALLBACK_VOICE_IDS=custom_voice_6c5fa792073cea70bc19314f26
# Standard-Default fuer guenstigere/robustere Demo- und Kundenauswahl.
RETELL_DEFAULT_STANDARD_VOICE_ID=custom_voice_6c5fa792073cea70bc19314f26
RETELL_DEFAULT_STANDARD_VOICE_MODEL=sonic-3-latest
RETELL_DEFAULT_STANDARD_VOICE_TEMPERATURE=0.55
RETELL_DEFAULT_STANDARD_FALLBACK_VOICE_IDS=custom_voice_74a89687ae8c8f1ad19e239e7c

# === Feature Flags ===
# Outbound-Calls für Kunden aktivieren (default OFF — nur Demo-Callback).
CUSTOMER_OUTBOUND_ENABLED=false
# Auto-Apply von outbound_suggestions ohne Human-Gate (default OFF, Risiko!).
OUTBOUND_AUTO_APPLY=false

# === Retell Tool-URL Auth ===
# HMAC-Schlüssel für Retell-Tool-URL-Signaturen (tool_sig query-Param).
# Audit-Round-15: soft-warn-Phase. Wenn leer, fällt der Code auf JWT_SECRET
# zurück (agent-config.ts:554 + retell-webhooks.ts:271). Identisch zu
# WEBHOOK_SIGNING_SECRET-Migration R7→R13: setze diesen Wert auf prod
# = JWT_SECRET BEVOR du JWT_SECRET rotierst, sonst brechen die Tool-URL-
# Validierungen aller bereits deployten Retell-Agents (alle existierenden
# tool_sig-Werte sind mit dem aktuellen JWT_SECRET signiert).
# Sobald gesetzt, kann JWT_SECRET unabhängig rotiert werden. Wird in einer
# folgenden Round zu hard-required promoted.
RETELL_TOOL_AUTH_SECRET=

# === Encryption ===
# AES-256-GCM-Key für OAuth-Tokens. Pflicht in prod, 64 hex chars.
# Generieren: openssl rand -hex 32
ENCRYPTION_KEY=
# State-Parameter-Signatur für OAuth-Flows (CSRF-Schutz).
OAUTH_STATE_SECRET=

# === SIP Trunk (Twilio → Retell routing) ===
# Pflicht in prod (Boot-Throw wenn fehlend). Für dev: Defaults greifen.
SIP_TRUNK_USERNAME=
SIP_TRUNK_PASSWORD=
SIP_TERMINATION_URI=anfangtelebot.pstn.twilio.com

# === Twilio Regulatory Bundle (für deutsche Nummern-Provisionierung) ===
# Pflicht in prod (Boot-Throw). Twilio Dashboard → Phone Numbers → Regulatory Bundles.
TWILIO_BUNDLE_SID=BU...
TWILIO_ADDRESS_SID=AD...

# === Phone-Prefix-Whitelist (Anti-Toll-Fraud) ===
# Kommagetrennt. Alle outbound-dial + ticket-callback + phone-forwarding Pfade
# validieren hiergegen. Default DACH. Erweitern für international.
ALLOWED_PHONE_PREFIXES=+49,+43,+41

# === Demo Global Hourly Cap ===
# Max demo/call + demo/callback Requests global pro Stunde (Redis-Counter).
# Schützt gegen Botnet cost-amplification. Default 200.
DEMO_GLOBAL_HOURLY_CAP=200

# === Cloudflare Turnstile (CAPTCHA für /demo/*, /outbound/website-callback) ===
# Erstellen: dash.cloudflare.com → Turnstile → Add site → Managed mode.
# Beide Keys werden bei Site-Erstellung angezeigt (beginnen mit 0x...).
# Site-Key wandert auch ins Frontend (apps/web/.env als VITE_TURNSTILE_SITE_KEY) — er ist öffentlich exposable.
# Secret-Key bleibt nur hier (server-side verify gegen challenges.cloudflare.com).
# In Dev ohne Secret-Key skippt verifyTurnstile() (true); in prod fail-closed (false).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# === Admin-Portal ===
# Entweder ADMIN_PASSWORD_HASH (bcrypt, empfohlen) oder ADMIN_PASSWORD (plaintext).
# Hash generieren: node -e "console.log(require('bcrypt').hashSync('dein-pw', 12))"
ADMIN_PASSWORD_HASH=
# Fallback nur für dev — in prod wird der Hash bevorzugt und Plaintext ist im
# docker-inspect/env-dump sichtbar.
ADMIN_PASSWORD=

# === DrKalla central knowledge auto-refresh ===
# Website-Scrape -> zentrale Postgres-Tabelle (kanonisches Wissen für ALLE
# Agenten) -> deterministische Ableitung -> Hot-Swap der Voice-Snapshots im
# laufenden Prozess (kein Neustart). Fail-soft: schlechter Scrape/DB-Ausfall
# behält den letzten guten Stand. Manuell: POST /retell/custom-llm/drkalla/
# admin/refresh-central (Auth: DRKALLA_ADMIN_PUBLISH_SECRET).
DRKALLA_CENTRAL_REFRESH_ENABLED=false
DRKALLA_CENTRAL_REFRESH_HOURS=24
DRKALLA_CENTRAL_REFRESH_BOOT_DELAY_MS=300000

# === Node ===
NODE_ENV=production
PORT=3001
