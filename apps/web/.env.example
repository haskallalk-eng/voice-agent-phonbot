# =============================
# Phonbot Web — Umgebungsvariablen (Vite)
# =============================
# Alle VITE_* Vars werden in den Build kompiliert (öffentlich!).
# Niemals Secrets hier — nur public keys + DSNs.

# Sentry DSN (optional) — Error-Tracking im Frontend.
# Leer lassen um Sentry zu deaktivieren.
VITE_SENTRY_DSN=

# Stripe Publishable Key (öffentlich, startet mit pk_test_ oder pk_live_).
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Cloudflare Turnstile Site-Key (öffentlich, mirror vom Backend TURNSTILE_SITE_KEY).
# Erstellen: dash.cloudflare.com → Turnstile → Add site.
VITE_TURNSTILE_SITE_KEY=0x...
