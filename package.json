{
  "name": "voice-agent-saas",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm --filter @vas/api typecheck && pnpm --filter @vas/web typecheck",
    "seo:generate": "node scripts/gen-landing-pages.mjs && node scripts/gen-seo-cluster-pages.mjs && node scripts/gen-seo-manifests.mjs && node scripts/sync-legal-nav.mjs",
    "seo:audit": "node scripts/seo-audit.mjs",
    "retell:sync": "node scripts/sync-retell-agent-tools.mjs",
    "retell:cleanup:dry": "node scripts/cleanup-retell-orphans.mjs",
    "retell:cleanup": "node scripts/cleanup-retell-orphans.mjs --execute --include-unreferenced --clean-phone-only",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript-eslint": "^8.59.2"
  }
}
