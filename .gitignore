# pnpm-lock.yaml intentionally tracked (needed for Docker --frozen-lockfile)


# Live agent coordination — never tracked.
# `.coordination/` is the canonical inter-agent scratch (vaso+termi); see
# `.coordination/memory/RULES.md` §15. `.collab/` was a short-lived parallel
# termi-bootstrap on 2026-04-15 that got consolidated into `.coordination/`
# the same day. Both patterns ignored defensively.
.coordination/
.collab/

# ── Secret-Hygiene (CLAUDE.md §17) ───────────────────────────────────────────
# Belt-and-suspenders on top of the pre-commit secret scanner in .githooks/.
# Keys, certs, and throwaway DB smoke-tests must never be tracked.
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
secrets/
.secrets/
# Common ad-hoc DB/test scripts — have repeatedly landed with hardcoded DSNs.
# If you need one, put it under apps/api/scratch/ (ignored) or read DATABASE_URL
# from process.env so the pre-commit scanner lets it through.
test-db.mjs
test-migrate.mjs
**/scratch/
**/tmp-*.mjs
**/tmp-*.ts

# Compliance — only signed contracts + DPF-Screenshots stay outside the repo.
# Eigene TIA-Bewertungen, VVT (.md), Mail-Templates und DPA-Vorlage sind
# Mindrails-interne Dokumente, keine Anbieter-Geheimnisse — die werden
# getrackt damit Team + Audits Zugriff haben.
compliance/dpas/
compliance/dpf-verifications/
compliance/vvt.xlsx
compliance/vvt.csv
