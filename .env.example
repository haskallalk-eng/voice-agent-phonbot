# ===== Database =====
DATABASE_URL=postgresql://user:password@localhost:5432/voice_agent

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== Auth =====
JWT_SECRET=generate-a-random-64-char-hex-string

# ===== Retell AI =====
RETELL_API_KEY=key_your_retell_api_key
RETELL_LLM_MODEL=gpt-4o-mini

# ===== Twilio (Inbound Phone) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== Webhook URLs =====
# Public URL where Retell can reach your API (use ngrok for dev)
WEBHOOK_BASE_URL=https://your-server.example.com
TWILIO_WEBHOOK_BASE_URL=https://your-server.example.com

# ===== Stripe Billing =====
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly prices
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...
# Yearly prices (optional — enables yearly billing toggle)
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_AGENCY_YEARLY=price_...

# ===== Email (Resend) =====
RESEND_API_KEY=re_...
EMAIL_FROM=Voice Agent <noreply@yourdomain.com>

# ===== OpenAI (Web Chat) =====
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ===== Google Calendar OAuth =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/calendar/google/callback

# ===== Error Tracking =====
SENTRY_DSN=

# ===== App =====
APP_URL=http://localhost:5173
PORT=3001
NODE_ENV=development

# ===== Docker Compose (optional) =====
DOMAIN=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=voice_agent

RETELL_OUTBOUND_NUMBER=+49...
