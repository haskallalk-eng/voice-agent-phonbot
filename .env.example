# =
# PHONBOT API — Umgebungsvariablen
# =

# =
# Supabase → Project → Settings → Database → Connection string (URI)
DATABASE_URL=

# =
REDIS_URL=

# =
# Beliebiger langer zufälliger String (mind. 32 Zeichen)
JWT_SECRET=

# =
# Retell Dashboard → API Keys
RETELL_API_KEY=
RETELL_LLM_MODEL=
# Retell Dashboard → Phone Numbers → deine provisionierte Nummer (Format: +49...)
RETELL_OUTBOUND_NUMBER=

# =
# Stripe Dashboard → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=
# Stripe Dashboard → Developers → Webhooks → dein Endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe Dashboard → Products → jeweiliger Preis → Price ID
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=
# Jährliche Preise (optional)
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_YEARLY=

# =
# Resend Dashboard → API Keys
RESEND_API_KEY=
EMAIL_FROM=

# =
APP_URL=

# =
WEBHOOK_BASE_URL=

# =
# Twilio Console → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_BASE_URL=

# =
# platform.openai.com → API Keys
OPENAI_API_KEY=
OPENAI_MODEL=

# =
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# =
# Azure Portal → deine App → Overview → "Application (client) ID"
MICROSOFT_CLIENT_ID=
# Azure Portal → deine App → Certificates & secrets → Value (nicht Secret ID!)
MICROSOFT_CLIENT_SECRET=

MICROSOFT_REDIRECT_URI=

# =
SENTRY_DSN=

# =
NODE_ENV=
PORT=
